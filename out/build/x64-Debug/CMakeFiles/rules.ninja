rule RERUN_CMAKE
  command = "C:\Program Files\Microsoft Visual Studio\2022\Community\Common7\IDE\CommonExtensions\Microsoft\CMake\CMake\bin\cmake.exe" --regenerate-during-build -SC:\Users\alexp\GitHub\LearnWebGPU-Code -BC:\Users\alexp\GitHub\LearnWebGPU-Code\out\build\x64-Debug
  description = Re-running CMake...
  generator = 1


